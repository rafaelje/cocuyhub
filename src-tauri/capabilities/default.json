{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "CocuyHub default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "opener:default",
    "updater:default",
    "window-state:allow-restore-state",
    "window-state:allow-save-window-state"
  ]
}
