{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "master-panel",
  "version": "0.1.0",
  "identifier": "com.rafaelje.master-panel",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "master-panel",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "TODO: https://github.com/YOUR_ORG/master-panel/releases/latest/download/latest.json"
      ],
      "pubkey": "TODO: generated via tauri signer generate"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
